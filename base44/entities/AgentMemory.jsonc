{
  "name": "AgentMemory",
  "type": "object",
  "properties": {
    "chave": {
      "type": "string",
      "description": "Chave identificadora do padr\u00e3o aprendido (ex: marca_havaianas_material)"
    },
    "valor": {
      "type": "string",
      "description": "Valor aprendido (ex: borracha natural)"
    },
    "tipo": {
      "type": "string",
      "enum": [
        "padrao_produto",
        "preferencia_usuario",
        "categoria_marketplace"
      ],
      "description": "Tipo de mem\u00f3ria"
    },
    "marketplace": {
      "type": "string",
      "description": "Marketplace relacionado (opcional)"
    },
    "tipo_produto": {
      "type": "string",
      "description": "Tipo de produto relacionado"
    },
    "uso_count": {
      "type": "number",
      "default": 1,
      "description": "Quantas vezes esse padr\u00e3o foi usado"
    },
    "ultima_atualizacao": {
      "type": "string",
      "format": "date",
      "description": "Data da \u00faltima atualiza\u00e7\u00e3o"
    },
    "company_id": {
      "type": "string"
    }
  },
  "required": [
    "chave",
    "valor",
    "tipo"
  ]
}